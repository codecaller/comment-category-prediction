p.argsort(label_coefs)[:15]\n    all_idx = np.concatenate([top_idx, bottom_idx])\n   \n    colors = np.where(label_coefs[all_idx] > 0, '#DB1A1A' , \"#2FA4D7\")\n    features = [name.split('__')[1] for name in feature_names[all_idx]]\n\n    sns.barplot(\n        y = features,\n        x = label_coefs[all_idx], \n        ax = axes[label],\n        palette = colors\n    )\n    axes[label].set_title(f'Label : {label}')\n    axes[label].axvline(x = 0, color = 'black', linewidth = 0.4)\n    axes[label].set_xlim(-7, 7)\n\nplt.tight_layout()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-26T02:36:31.448081Z","iopub.execute_input":"2026-03-26T02:36:31.449018Z","iopub.status.idle":"2026-03-26T02:36:33.650798Z","shell.execute_reply.started":"2026-03-26T02:36:31.448984Z","shell.execute_reply":"2026-03-26T02:36:33.650039Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 1200x1200 with 4 Axes>","image/png":"\n"},"metadata":{}}],"execution_count":141},{"cell_type":"markdown","source":"### Top Feature Coefficients — SGDClassifier\n\nFor each of the 4 classes, the 15 most **positive** (red) and 15 most **negative** (blue) coefficient features are shown.\n\n- **Positive coefficients (red):** Features that strongly push the model toward predicting this class.\n- **Negative coefficients (blue):** Features that push the model *away* from predicting this class (i.e. evidence for other classes).","metadata":{}},{"cell_type":"markdown","source":"## 2. Linear SVC :","metadata":{}},{"cell_type":"markdown","source":"`LinearSVC` finds a **maximum-margin linear decision boundary** using the squared-hinge loss. It is typically faster than kernel SVMs and well-suited to high-dimensional sparse text data.\n\nKey settings:\n\n- **`penalty='l2'`**: L2 regularisation on the weight vector.\n- **`C=0.1`**: inverse regularisation strength — smaller C means stronger regularisation (wider margin, fewer support vectors).\n- **`class_weight='balanced'`**: